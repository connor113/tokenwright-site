---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Route not found · Tokenwright">
  <header class="masthead">
    <div class="topbar">
      <span class="brand mono">tokenwright.ai</span>
      <nav>
        <a href="/">home</a>
      </nav>
    </div>
  </header>

  <section class="section">
    <div class="error-wrap">
      <div class="error-code mono">ERROR.404</div>
      <h1 class="error-msg">Route not found</h1>
      <p class="error-return mono">
        RETURN TO ROOT &rarr; <a href="/">tokenwright.ai</a>
      </p>
    </div>
  </section>
</BaseLayout>
